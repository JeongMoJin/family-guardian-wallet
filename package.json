{
  "name": "family-guardian-wallet",
  "version": "0.1.0",
  "private": true,
  "description": "XRPL multisig PoC for senior guardian wallet",
  "scripts": {
    "create-accounts": "tsx src/scripts/01-create-accounts.ts",
    "setup-signers": "tsx src/scripts/02-setup-signers.ts",
    "demo": "tsx src/scripts/03-demo-payment.ts",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "npm --prefix web run dev",
    "dev": "concurrently -n server,web -c blue,magenta \"npm run dev:server\" \"npm run dev:web\"",
    "build": "npm --prefix web install --no-audit --no-fund && npm --prefix web run build",
    "start": "tsx src/server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "tsx": "^4.7.0",
    "xrpl": "^3.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.4.0"
  }
}
